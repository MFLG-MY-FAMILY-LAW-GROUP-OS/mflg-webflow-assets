{
  "version": "0.6.0-pdf-candidates",
  "purpose": "Jurisdiction-aware public planning catalog for Arizona family-law form resources. Public tools must avoid sensitive facts before conflict, scope, and engagement review.",
  "safe_public_fields": [
    "matter_key",
    "county",
    "existing_case",
    "children_involved",
    "served_or_deadline",
    "filing_posture",
    "selected_form_set"
  ],
  "restricted_public_fields": [
    "full_opposing_party_names",
    "child_names_or_birth_dates",
    "account_numbers",
    "document_uploads",
    "detailed_abuse_allegations",
    "full_financial_disclosures",
    "strategy_narratives"
  ],
  "maintenance": {
    "owner": "internal-source-monitoring",
    "review_required_for": [
      "broken official links",
      "changed source page hash",
      "changed PDF hash",
      "new effective date",
      "removed form",
      "county-specific packet conflict"
    ],
    "fallback_rule": "If source status is stale, broken, or needs_review, show the official court library page instead of cached downloads."
  },
  "schema": {
    "form_set_id": "string",
    "matter_keys": ["string"],
    "jurisdiction": "statewide|county",
    "county": "string|null",
    "court": "string",
    "filing_posture": "new|response|agreement|post_decree|enforcement|hearing|disclosure|safety|unknown",
    "children_required": "yes|no|unknown",
    "label": "string",
    "official_url": "url",
    "source_page_url": "url",
    "cached_file_url": "url|null",
    "status": "active|fallback|needs_review|pending_catalog",
    "last_checked_at": "ISO-8601|null",
    "last_verified_at": "ISO-8601|null",
    "hash": "string|null"
  },
