    "owner": "internal-source-monitoring",
    "review_required_for": [
      "broken official links",
      "changed source page hash",
      "changed PDF hash",
      "new effective date",
      "removed form",
      "county-specific packet conflict"
    ],
    "fallback_rule": "If source status is stale, broken, or needs_review, show the official court library page instead of cached downloads."
  },
